{
  "manifest_version": 3,
  "name": "Web Motion Prompt Studio",
  "version": "0.1.0",
  "description": "Analyze website visuals and motion, then generate reusable Chinese prompts.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Analyze website prompts",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["activeTab", "scripting"]
}
